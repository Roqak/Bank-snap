<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed Bubble -->
    <LinearLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bubble_background"
        android:padding="10dp"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/bubble_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/bubble_icon_bg"
            android:padding="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/bubble_bank_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank App"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bubble_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#A5D6A7"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/bubble_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:indeterminateTint="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/bubble_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing..."
                    android:textColor="#FFCC80"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:alpha="0.7" />
    </LinearLayout>

    <!-- Expanded Control Panel -->
    <LinearLayout
        android:id="@+id/expanded_view"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_expanded_bg"
        android:padding="14dp"
        android:layout_marginTop="75dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Amount Quick Buttons -->
        <LinearLayout
            android:id="@+id/amount_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_quick_1000"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="₦1k"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btn_quick_2000"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="₦2k"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btn_quick_5000"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="₦5k"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btn_quick_10000"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="₦10k"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:padding="0dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/action_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_other"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="Other"
                android:textSize="11sp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:padding="0dp" />

            <Button
                android:id="@+id/btn_done"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="PIN 🔒"
                android:textSize="11sp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"
                android:padding="0dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_recheck"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="🔄 Recheck Screen"
            android:textSize="11sp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:layout_marginTop="6dp"
            android:padding="0dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap buttons to fill fields. PIN must be entered manually."
            android:textColor="#90A4AE"
            android:textSize="9sp"
            android:layout_marginTop="6dp"
            android:gravity="center" />
    </LinearLayout>
</FrameLayout>
